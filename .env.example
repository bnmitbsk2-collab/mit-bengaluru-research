# ── Portal mode ──────────────────────────────────────────────────────────────
# demo        = sample data, demo banner, free deployment (default)
# production  = CMS + PostgreSQL after director approval
PORTAL_MODE=demo

# Show amber demo banner (set false to hide while still in demo mode)
NEXT_PUBLIC_DEMO_BANNER=true

# ── Production only (Phase 1 post-approval) ──────────────────────────────────
# PORTAL_MODE=production
# NEXT_PUBLIC_PORTAL_MODE=production
# NEXT_PUBLIC_DEMO_BANNER=false
# ── Vercel + Neon (free deploy) — see docs/DEPLOY-FREE.md ────────────────────
# DATABASE_URI=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# CMS_URL=https://your-project.vercel.app
# PAYLOAD_SECRET=change-me-min-32-characters-long
# CMS_URL=http://localhost:3000
# ADMIN_PASSWORD=ChangeMe123!
# CMS_API_KEY=
# ENQUIRY_NOTIFY_EMAIL=research.blr@manipal.edu

# ── SSO — Microsoft Entra ID (MAHE IT) ───────────────────────────────────────
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# AZURE_AD_ADMIN_GROUP_ID=   # optional: restrict to Entra security group

# ── Optional: analytics (Phase 1) ──────────────────────────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
